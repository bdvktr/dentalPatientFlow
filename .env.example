# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from resend.com
RESEND_API_KEY=re_your_key

# Resend sender address — must be a verified domain
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Resend webhook signing secret — get from Resend dashboard > Webhooks
# Required in production for the /api/webhooks/resend endpoint to accept events
RESEND_WEBHOOK_SECRET=whsec_your_secret

# OpenAI — optional, used only for AI draft replies
OPENAI_API_KEY=sk-your-key

# Vercel Cron secret — used to authenticate /api/cron/follow-ups
CRON_SECRET=your-random-secret

# Base URL — used for generating absolute URLs in emails
NEXT_PUBLIC_BASE_URL=http://localhost:3000
